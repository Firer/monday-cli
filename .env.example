# Monday.com API token (required).
# Generate one at: https://<your-org>.monday.com/admin/integrations/api
# Admins/members only — guests cannot mint API tokens.
MONDAY_API_TOKEN=

# Optional: pin to a specific Monday API version (header `API-Version`).
# Default behaviour: send no header, which makes Monday return its current
# stable version. Pin this when you need reproducible behaviour across
# Monday's quarterly version bumps. Format: YYYY-MM (e.g. 2026-04).
# MONDAY_API_VERSION=2026-04

# Optional: override the GraphQL endpoint (rarely needed — useful for
# self-hosted gateways or recording tests against a fixture server).
# MONDAY_API_URL=https://api.monday.com/v2

# Optional: per-request timeout in milliseconds (default: 30000).
# MONDAY_REQUEST_TIMEOUT_MS=30000
